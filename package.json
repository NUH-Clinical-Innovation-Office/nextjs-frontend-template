{
  "name": "nextjs-frontend-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": "26.3.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "biome check",
    "format": "biome check --write",
    "type-check": "tsc --noEmit",
    "analyze": "ANALYZE=true next build --webpack",
    "security-scan": "echo '=== Running Trivy Security Scans ===' && echo '\n[1/3] Scanning dependencies and configurations...' && trivy fs . --severity CRITICAL --scanners vuln,misconfig --skip-dirs docs && echo '\n[2/3] Scanning Dockerfile...' && trivy config Dockerfile --severity CRITICAL && echo '\n[3/3] Scanning Helm charts...' && trivy config helm/ --severity CRITICAL && echo '\n✓ Security scan complete!'",
    "security-scan:image": "echo 'Building and scanning Docker image...' && IMAGE_TAG=$(git rev-parse --short HEAD) && docker build -t nextjs-frontend-template:$IMAGE_TAG . && trivy image nextjs-frontend-template:$IMAGE_TAG --severity CRITICAL",
    "prepare": "husky",
    "knip": "knip",
    "update:packages": "bun update --latest",
    "check:all": "bun run lint && bun run type-check && bun run knip"
  },
  "dependencies": {
    "@radix-ui/react-switch": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "prom-client": "^15.1.3",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@happy-dom/global-registrator": "^20.10.2",
    "@next/bundle-analyzer": "^16.2.9",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  }
}
